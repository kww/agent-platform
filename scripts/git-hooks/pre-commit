#!/bin/bash
# Git pre-commit hook - 偏离检测触发
# 
# WA-007: Git pre-commit hook（0.5h）
#
# 功能：
# 1. 检查 constraintLevel（L3/L4 才触发）
# 2. 调用 API 检查偏离
# 3. 偏离时 git stash + 触发 SpecReview
# 4. 阻止 commit

set -e

TASK_CONTEXT=".task-context"

# 检查是否有 Task 上下文
if [ ! -f "$TASK_CONTEXT" ]; then
  # 没有 Task 上下文 → 普通 commit，允许
  exit 0
fi

# 读取 Task 上下文
TASK_ID=$(jq -r '.taskId' "$TASK_CONTEXT" 2>/dev/null || echo "")
EXECUTION_ID=$(jq -r '.executionId' "$TASK_CONTEXT" 2>/dev/null || echo "")
CONSTRAINT_LEVEL=$(jq -r '.constraintLevel' "$TASK_CONTEXT" 2>/dev/null || echo "")
BASELINE=$(jq -r '.baselineDecision' "$TASK_CONTEXT" 2>/dev/null || echo "")

# 检查必要字段
if [ -z "$TASK_ID" ] || [ -z "$EXECUTION_ID" ]; then
  # 缺少必要字段 → 普通 commit，允许
  exit 0
fi

# 只检查 L3/L4
if [ "$CONSTRAINT_LEVEL" != "L3" ] && [ "$CONSTRAINT_LEVEL" != "L4" ]; then
  # L1/L2 → 快速通过，允许 commit
  exit 0
fi

echo "🔍 Checking baseline deviation for Task: $TASK_ID (Level: $CONSTRAINT_LEVEL)"

# 获取 git diff
GIT_DIFF=$(git diff --cached 2>/dev/null || echo "")

if [ -z "$GIT_DIFF" ]; then
  # 无变更 → 允许 commit
  echo "✅ No changes detected"
  exit 0
fi

# 调用 API 检查偏离
RESPONSE=$(curl -s -X POST "http://localhost:13101/api/v1/checkpoints/verify" \
  -H "Content-Type: application/json" \
  -d '{
    "taskId": "'"$TASK_ID"'",
    "executionId": "'"$EXECUTION_ID"'",
    "baseline": "'"$BASELINE"'",
    "gitDiff": "'"$GIT_DIFF"'",
    "checkType": "baseline_deviation"
  }' 2>/dev/null || echo '{"passed": true}')

# 解析结果
PASSED=$(jq -r '.passed' <<< "$RESPONSE" 2>/dev/null || echo "true")

if [ "$PASSED" = "true" ]; then
  # 无偏离 → 允许 commit
  echo "✅ Baseline check passed"
  exit 0
fi

# 有偏离 → 触发 SpecReview
SPEC_ID=$(jq -r '.specReviewId' <<< "$RESPONSE" 2>/dev/null || echo "")
DEVIATION=$(jq -r '.deviation.description' <<< "$RESPONSE" 2>/dev/null || echo "Unknown deviation")

echo "❌ Baseline deviation detected!"
echo "📋 Deviation: $DEVIATION"
echo "🚨 SpecReview ID: $SPEC_ID"

# Git stash（暂存代码）
STASH_REF=$(git stash push -m "spec-review-$SPEC_ID" 2>/dev/null || echo "")

if [ -n "$STASH_REF" ]; then
  echo "📦 Code stashed: $STASH_REF"
  
  # 写入等待标记
  jq -n --arg specId "$SPEC_ID" --arg stashRef "$STASH_REF" \
    '{"specReviewId": $specId, "stashed": true, "stashRef": $stashRef}' \
    > ".spec-review-pending"
fi

echo ""
echo "⏳ Workflow blocked, waiting for SpecReview approval..."
echo "   Review URL: http://localhost:3000/spec-reviews/$SPEC_ID"
echo ""

# 阻止 commit
exit 1