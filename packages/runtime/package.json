{
  "name": "@dommaker/runtime",
  "version": "0.0.4",
  "description": "AI Agent 工作流执行引擎 - npm 包 + CLI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-runtime": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "golden:list": "ts-node scripts/golden-master-cli.ts list",
    "golden:record": "ts-node scripts/golden-master-cli.ts record",
    "golden:verify": "ts-node scripts/golden-master-cli.ts verify",
    "golden:verify-all": "ts-node scripts/golden-master-cli.ts verify-all",
    "bench:list": "ts-node -e \"require('./dist/monitoring/performance-regression')\"",
    "bench:record": "ts-node -e \"const { recordBaseline } = require('./dist/monitoring/performance-regression'); recordBaseline(process.argv[1]).catch(console.error)\" --",
    "bench:check": "ts-node -e \"const { detectRegression } = require('./dist/monitoring/performance-regression'); detectRegression(process.argv[1]).catch(console.error)\" --",
    "bench:check-all": "ts-node -e \"const { detectAllRegressions } = require('./dist/monitoring/performance-regression'); detectAllRegressions().catch(console.error)\"",
    "bench:update": "ts-node -e \"const { updateBaseline } = require('./dist/monitoring/performance-regression'); updateBaseline(process.argv[1]).catch(console.error)\" --",
    "quality:score": "ts-node -e \"const { calculateQualityScore } = require('./dist/monitoring/quality-scorer'); calculateQualityScore(process.argv[1]).then(s => console.log(JSON.stringify(s, null, 2))).catch(console.error)\" --",
    "quality:all": "ts-node -e \"const { calculateAllScores } = require('./dist/monitoring/quality-scorer'); calculateAllScores().then(s => console.log(JSON.stringify(s, null, 2))).catch(console.error)\"",
    "quality:list": "ts-node -e \"const { listScores } = require('./dist/monitoring/quality-scorer'); console.log(JSON.stringify(listScores(), null, 2))\"",
    "quality:report": "ts-node -e \"const { generateQualityReport } = require('./dist/monitoring/quality-scorer'); generateQualityReport(process.argv[1]).then(r => console.log(JSON.stringify(r, null, 2))).catch(console.error)\" --"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "automation",
    "cli"
  ],
  "author": "kww",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dommaker/harness": "link:/root/projects/harness",
    "@dommaker/workflows": "^0.0.1",
    "chalk": "^4.1.2",
    "js-yaml": "^4.1.0",
    "yaml": "^2.8.3",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eventemitter3": "^5.0.1",
    "express": "^5.2.1",
    "https-proxy-agent": "^7.0.6",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "undici": "^8.0.0",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/uuid": "^9.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kww/agent-platform.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/kww/agent-platform/issues"
  },
  "homepage": "https://github.com/kww/agent-platform#readme"
}
