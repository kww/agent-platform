{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["npm"],
  "schedule": ["after 2am on Monday"],
  "packageRules": [
    {
      "matchPackagePatterns": ["@dommaker/harness"],
      "groupName": "harness",
      "automerge": true,
      "minimumReleaseAge": "1h"
    },
    {
      "matchPackagePatterns": ["*"],
      "excludePackagePatterns": ["@dommaker/harness"],
      "enabled": false
    }
  ]
}
